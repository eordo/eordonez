{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@/components/*": ["./src/components/*"],
      "@/data/*": ["./src/data/*"],
      "@/images/*": ["./src/assets/images/*"],
      "@/layouts/*": ["./src/layouts/*"],
      "@/styles/*": ["./src/styles/*"]
    }
  }
}
