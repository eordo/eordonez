---
interface Props {
    side: "left" | "right"
}

const { side } = Astro.props;
---

<aside class={`site-margin-${side}`}>
    <slot />
</aside>

<style>
    .site-margin-left {
        grid-area: left;
        display: flex;
        flex-direction: column;
        gap: var(--space-8);
        padding: var(--space-4) 0;
    }

    .site-margin-right {
        grid-area: right;
    }
</style>
