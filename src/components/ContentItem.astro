---
const {
    href,
    title,
    description,
    primaryTag,
    date,
    name = "work"
} = Astro.props;

import { formatYear } from "@/utils/date";
---

<details class="collapsible" name={name}>
    <summary>
        <div class="summary-content">
            <span class="title">{title}</span>
            <span class="meta">{primaryTag} &mdash; {formatYear(date)}</span>
        </div>
    </summary>
    <div class="details-content">
        <p class="description">{description}</p>
        <a href={href} class="link">Read more...</a>
    </div>
</details>

<style>    
    details:hover summary .summary-content .title {
        font-weight: 500;
        transition: font-weight 120ms ease;
    }
    
    details[open] summary .summary-content .title {
        font-weight: 500;
    }

    .summary-content {
        display: flex;
        flex-direction: column;
        padding: var(--space-1) 0;
    }

    .summary-content .title {
        font-weight: 400;
    }

    .details-content .description,
    .details-content .link {
        margin: 0;
    }
</style>
