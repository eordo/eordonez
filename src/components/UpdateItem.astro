---
import { formatDate } from "@/utils/date";

const { date, text, url = null } = Astro.props;
---

<li>
    <time class="meta" datetime={date}>{formatDate(date)}</time>
    <span>{url ? <a href={url}>text</a> : text}</span>
</li>

<style>
    li {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
        align-items: start;
        margin-bottom: var(--space-3);
    }
</style>
