---
import BaseLayout from "@layouts/BaseLayout.astro";
const pageTitle = "Blog";
const allPosts = Object.values(import.meta.glob("./blog/*.md", { eager: true }))
    .sort((a: any, b: any) => Date.parse(b.frontmatter.pubDate) - Date.parse(a.frontmatter.pubDate));
---

<BaseLayout pageTitle={pageTitle}>
    <h1>{pageTitle}</h1>
    <section id="all-posts">
        <p>Here is the <a href="https://xkcd.com/148/">blag of my wobsite</a>.</p>
        <ul>
            {allPosts.map((post: any) => <li><a href={post.url}>{post.frontmatter.title}</a></li>)}
        </ul>
    </section>
</BaseLayout>
