---
import "@/styles/global.css";

import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteMargin from "@/components/SiteMargin.astro";

const { title } = Astro.props;
const hasLeftMargin = Astro.slots.has("left-margin");
const hasRightMargin = Astro.slots.has("right-margin");
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=JetBrains+Mono:wght@100..800&family=STIX+Two+Text:ital,wght@0,400..700;1,400..700&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
        <title>{title} | Eric Ordoñez</title>
    </head>
    <body>
        <div
            class:list={[
                "container",
                hasLeftMargin && "has-left",
                hasRightMargin && "has-right"
            ]}
        >
            <SiteHeader />
            {(hasLeftMargin &&
                <SiteMargin side="left">
                    <slot name="left-margin" />
                </SiteMargin>
            )}
            <main class="content-width">
                <slot />
            </main>
            {(hasRightMargin &&
                <SiteMargin side="right">
                    <slot name="right-margin" />
                </SiteMargin>
            )}
            <SiteFooter />
        </div>
    </body>
</html>
